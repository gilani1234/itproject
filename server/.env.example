PORT=3001
CORS_ORIGIN=http://localhost:5173

# We'll use Prisma with Postgres; set this after Postgres is running.
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/virtual_it_company?schema=public"
DATABASE_URL=

# JWT secret for auth (set any long random string)
JWT_SECRET=

# Optional: allow creating TEACHER accounts via /api/auth/register with role=TEACHER
TEACHER_INVITE_CODE=

