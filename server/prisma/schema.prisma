generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum TeamRole {
  MEMBER
  LEAD
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum AuditAction {
  TASK_CREATE
  TASK_UPDATE
  TASK_DELETE
  TASK_LOCK
  TASK_UNLOCK
  SPRINT_CREATE
  SPRINT_UPDATE
  SPRINT_CLOSE
  SPRINT_LOCK
  SPRINT_UNLOCK
  MESSAGE_CREATE
  MESSAGE_DELETE
  FILE_UPLOAD
  FILE_DELETE
  MEMBER_ADD
  MEMBER_REMOVE
  TEAM_CREATE
  TEAM_UPDATE
}

enum ControlType {
  RK1
  RK2
  EXAM
}

enum AchievementType {
  FIRST_TASK
  SPRINT_LEADER
  PERFECT_ATTENDANCE
  TEAM_PLAYER
  CODE_REVIEWER
  LEADER
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String
  passwordHash String
  role         Role         @default(STUDENT)
  rating       Int          @default(0)
  totalPoints  Int          @default(0)
  avatar       String?      // URL to avatar image
  bio          String?      // User bio/about
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships     TeamMember[]
  assigned        Task[]       @relation("TaskAssignee")
  createdTasks    Task[]       @relation("TaskCreator")
  messages        Message[]
  taskComments    TaskComment[]
  taskHistory     TaskHistory[]
  ratings         SprintRating[]
  auditLogs       AuditLog[]
  
  reviewsGiven    PeerReview[] @relation("ReviewsGiven")
  reviewsReceived PeerReview[] @relation("ReviewsReceived")
  individualTasks IndividualTask[]
  plannings       SprintPlanning[] @relation("PlanningCreator")
  reviews         SprintReview[] @relation("ReviewCreator")
  retros          Retrospective[] @relation("RetroCreator")
  notifications   Notification[]
  achievements    Achievement[]
  controlResults  ControlResult[]
  controlsCreated ControlPoint[]
  
  lessonsCreated    Lesson[]
  lessonCompletions LessonCompletion[]
  quizSubmissions   QuizSubmission[]
}

model Team {
  id        String       @id @default(uuid())
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   TeamMember[]
  sprints   Sprint[]
  tasks     Task[]
  messages  Message[]
  plannings SprintPlanning[]
  reviews   SprintReview[]
  retros    Retrospective[]
  controls  ControlPoint[]
  lessons   Lesson[]
}

model TeamMember {
  id        String    @id @default(uuid())
  teamId    String
  userId    String
  teamRole  TeamRole  @default(MEMBER)
  joinedAt  DateTime  @default(now())

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Sprint {
  id           String    @id @default(uuid())
  teamId       String
  name         String
  startsAt     DateTime
  endsAt       DateTime
  isClosed     Boolean   @default(false)
  isLocked     Boolean   @default(false)
  scumMasterId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks      Task[]
  ratings    SprintRating[]
  plannings  SprintPlanning[]
  reviews    SprintReview[]
  retros     Retrospective[]
}

model Task {
  id          String      @id @default(uuid())
  teamId      String
  sprintId    String?

  title       String
  description String?
  status      TaskStatus  @default(BACKLOG)
  points      Int?
  deadline    DateTime?
  order       Int         @default(0)
  isLocked    Boolean     @default(false)

  assigneeId  String?
  createdById String

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sprint      Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  comments    TaskComment[]
  history     TaskHistory[]
  attachments TaskAttachment[]

  @@index([teamId, status])
  @@index([sprintId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  userId    String?
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  label     String
  url       String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(uuid())
  teamId      String
  userId      String
  text        String
  createdAt   DateTime @default(now())

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]

  @@index([teamId, createdAt])
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  label     String
  url       String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model SprintRating {
  id        String   @id @default(uuid())
  sprintId  String
  userId    String
  points    Int      @default(0)
  feedback  String?
  ratedBy   String
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt

  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sprintId, userId])
  @@index([userId, createdAt])
}

model AuditLog {
  id        String     @id @default(uuid())
  userId    String
  action    AuditAction
  entityType String
  entityId  String
  details   String?
  changedBy String?
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}

model PeerReview {
  id        String   @id @default(uuid())
  fromUserId String
  toUserId  String
  sprinkId  String?
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now())

  fromUser  User     @relation("ReviewsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser    User     @relation("ReviewsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
}

model IndividualTask {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  completed   Boolean  @default(false)
  dueDate     DateTime?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completed])
}

model SprintPlanning {
  id        String   @id @default(uuid())
  sprintId  String
  teamId    String
  content   String
  createdBy String
  createdAt DateTime @default(now())

  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator   User     @relation("PlanningCreator", fields: [createdBy], references: [id])

  @@index([sprintId])
}

model SprintReview {
  id        String   @id @default(uuid())
  sprintId  String
  teamId    String
  summary   String
  completed Int      @default(0)
  notCompleted Int @default(0)
  createdBy String
  createdAt DateTime @default(now())

  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator   User     @relation("ReviewCreator", fields: [createdBy], references: [id])

  @@index([sprintId])
}

model Retrospective {
  id        String   @id @default(uuid())
  sprintId  String
  teamId    String
  whatWent  String?
  whatFailed String?
  improvements String?
  createdBy String
  createdAt DateTime @default(now())

  sprint    Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator   User     @relation("RetroCreator", fields: [createdBy], references: [id])

  @@index([sprintId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("info")
  relatedId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Achievement {
  id        String     @id @default(uuid())
  userId    String
  type      AchievementType
  description String
  earnedAt  DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model ControlPoint {
  id        String     @id @default(uuid())
  teamId    String
  type      ControlType
  title     String
  description String?
  dueDate   DateTime?
  maxPoints Int        @default(100)
  createdBy String
  createdAt DateTime   @default(now())

  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator   User       @relation(fields: [createdBy], references: [id])
  results   ControlResult[]

  @@index([teamId, type])
}

model ControlResult {
  id          String   @id @default(uuid())
  controlPointId String
  userId      String
  score       Int      @default(0)
  feedback    String?
  submittedAt DateTime?
  createdAt   DateTime @default(now())

  controlPoint ControlPoint @relation(fields: [controlPointId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([controlPointId, userId])
}

// ====== LMS: LESSONS ======
model Lesson {
  id          String   @id @default(uuid())
  teamId      String
  title       String
  description String?
  order       Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team       Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator    User                @relation(fields: [createdBy], references: [id])
  contents   LessonContent[]
  quizzes    Quiz[]
  completions LessonCompletion[]

  @@index([teamId])
}

enum LessonContentType {
  FILE_PDF
  FILE_WORD
  FILE_POWERPOINT
  VIDEO_YOUTUBE
  TEXT
}

model LessonContent {
  id        String              @id @default(uuid())
  lessonId  String
  type      LessonContentType
  title     String
  url       String?             // YouTube URL or file URL
  text      String?             // For TEXT type
  order     Int                 @default(0)
  createdAt DateTime            @default(now())

  lesson    Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model LessonCompletion {
  id        String   @id @default(uuid())
  lessonId  String
  userId    String
  completedAt DateTime @default(now())

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([userId])
}

// ====== LMS: QUIZZES ======
model Quiz {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  description String?
  passingScore Int     @default(70)
  maxAttempts Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  submissions QuizSubmission[]

  @@index([lessonId])
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
}

model QuizQuestion {
  id        String        @id @default(uuid())
  quizId    String
  text      String
  type      QuestionType
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  quiz      Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   QuizOption[]
  answers   QuizAnswer[]

  @@index([quizId])
}

model QuizOption {
  id        String   @id @default(uuid())
  questionId String
  text      String
  isCorrect Boolean  @default(false)
  order     Int      @default(0)

  question  QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizSubmission {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  score     Int      @default(0)
  maxScore  Int      @default(100)
  passed    Boolean  @default(false)
  submittedAt DateTime @default(now())

  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   QuizAnswer[]

  @@index([quizId, userId])
  @@index([userId])
}

model QuizAnswer {
  id           String   @id @default(uuid())
  submissionId String
  questionId   String
  selectedOptionId String?
  textAnswer   String?
  isCorrect    Boolean  @default(false)

  submission   QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     QuizQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

